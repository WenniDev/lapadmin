<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
        // Applied before first paint to avoid a flash of personal info.
        if (localStorage.getItem('hide-personal-info') === '1') {
            document.documentElement.classList.add('hide-personal-info');
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            background: #f4f4f4;
            height: 100vh;
        }

        a {
            cursor: pointer;
        }


        a:hover {
            text-decoration: underline;
        }

        a:hover.material-icons, a:hover .material-icons {
            text-decoration: none;
        }

        span.badge {
            float: unset;
            color: white;
            font-weight: 300;
            font-size: 0.8rem;
            background-color: #26a69a;
            border-radius: 2px;
        }

        nav .brand-logo {
            left: 0;
            transform: none;
        }

        code {
            background: #f4f4f4;
            padding: 0.2em 0.4em;
            border-radius: 3px;
            font-size: 0.9em;
        }

        .material-icons {
            vertical-align: middle;
            position: relative;
            top: -0.1em;
        }

        .btn .material-icons {
            top: 0;
        }

        .widget {
            max-width: calc(100% - 20px);
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            background: white;
            padding: 1em;
            margin: 1em auto;
        }

        .box {
            padding: 1em;
            background: white;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            margin: 1em;
        }

        .flash-close {
            float: right;
            cursor: pointer;
        }

        html.hide-personal-info .personal-info {
            filter: blur(6px);
            user-select: none;
        }

        #settings-dropdown li {
            padding: 0.5em 1em;
        }
    </style>
    {% block styles %}{% endblock %}
</head>
<body>
    <nav>
        <div class="nav-wrapper container">
            <a href="{{ url_for('.index') }}" class="brand-logo">Lapadmin</a>
            <ul class="right">
                <li><a href="{{ url_for('.calendar_redirect') }}">Calendrier</a></li>
                <li><a href="{{ url_for('.calendar_day', month=now.format('YYYY-MM'), day=now.format('DD')) }}">Aujourd'hui</a></li>
                <li><a href="{{ url_for('.visitors') }}">Visiteurs</a></li>
                <li><a href="{{ url_for('.inventory') }}">Inventaire</a></li>
                <li><a href="{{ url_for('.streams_page') }}">Streams</a></li>
                <li>
                    <a class="dropdown-trigger" href="#!" data-target="settings-dropdown">
                        <i class="material-icons">settings</i>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <ul id="settings-dropdown" class="dropdown-content">
        <li>
            <label>
                <input type="checkbox" id="toggle-hide-personal-info">
                <span>Cacher les informations personnelles</span>
            </label>
        </li>
    </ul>
    <div class="container">
        {% for category, message in get_flashed_messages(with_categories=true) %}
        {% macro get_category_class(category) %}
        {% if category == 'error' %}
        red darken-1
        {% elif category == 'warning' %}
        orange darken-1
        {% elif category == 'success' %}
        green darken-1
        {% else %}
        blue lighten-4
        {% endif %}
        {% endmacro %}
        <div class="flash {{ category }} card-panel {{ get_category_class(category) }}">
            <span class="content">
                {{ message | e }}
            </span>
            <span class="flash-close">
                <span class="material-icons icon">close</span>
            </span>
        </div>
        {% endfor %}
    </div>

    {% block content %}{% endblock %}

    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            M.Datepicker.init(document.querySelectorAll('.datepicker'), {
                format: 'yyyy-mm-dd',
                firstDay: 1,
            });

            M.Timepicker.init(document.querySelectorAll('.timepicker'), {
                twelveHour: false,
            });

            M.FormSelect.init(document.querySelectorAll('select'));

            M.Dropdown.init(document.querySelectorAll('.dropdown-trigger'), {
                constrainWidth: false,
                coverTrigger: false,
                closeOnClick: false,
            });

            document.getElementById('settings-dropdown').addEventListener('click', function(event) {
                event.stopPropagation();
            });

            for (let el of document.querySelectorAll('.flash-close')) {
                el.addEventListener('click', function() {
                    this.parentElement.remove();
                });
            }

            const hidePersonalInfoToggle = document.getElementById('toggle-hide-personal-info');
            hidePersonalInfoToggle.checked = document.documentElement.classList.contains('hide-personal-info');
            hidePersonalInfoToggle.addEventListener('change', function() {
                document.documentElement.classList.toggle('hide-personal-info', this.checked);
                localStorage.setItem('hide-personal-info', this.checked ? '1' : '0');
            });
        });
    </script>
    {% block scripts %}{% endblock %}

</body>
</html>
