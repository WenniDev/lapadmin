{% extends "base.html.j2" %}
{% block styles %}
<style>
    #calendar {
        width: 100%;
        max-width: calc(700px + 2rem);
    }

    #calendar-quick-switch {
        display: flex;
        align-items: center;
    }

    #calendar a {
        text-decoration: none;
    }

    #calendar-quick-switch .material-icons {
        font-size: 3em;
    }

    #calendar [type="checkbox"] + span {
        padding-left: 24px;
    }

    #calendar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    #calendar-weekdays {
        text-align: center;
        margin-bottom: 1em;
    }

    #calendar .cell {
        height: 100px;
        border: 1px solid black;
        padding: 0.5em;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }


    #calendar .cell:hover {
        background: gold;
    }

    #calendar .weekend .cell-date { color: red }
    #calendar .past { background: rgb(230, 230, 230) }
    #calendar .opening { background: lightgreen }

    #calendar .cell-weekday {
        display: none;
    }

    #calendar .today:after {
        content: '';
        position: absolute;
        top: -20px;
        right: -20px;
        background: red;
        width: 40px;
        height: 40px;
        transform: rotate(45deg);
    }

    #calendar .calendar-row {
        display: flex;
    }

    #calendar .calendar-row > * {
        width: calc(100% / 7);
    }

    #calendar .cell {
        height: 100px;
    }

    @media screen and (max-width: 700px) {
        #calendar-weekdays.calendar-row {
            display: none;
        }

        #calendar .calendar-row {
            flex-direction: column;
        }

        #calendar .calendar-row > .cell {
            width: 100%;
        }

        #calendar .cell {
            height: auto;
            min-height: 48px;
            flex-direction: row;
            align-items: center;
            gap: 1em;
            padding: 0.5em 1em;
        }

        #calendar .cell-date {
            font-weight: bold;
            min-width: 1.5em;
        }

        #calendar .cell-weekday {
            display: inline;
            opacity: 0.7;
            min-width: 4em;
        }

        #calendar .staffings {
            flex: 1;
        }

        #calendar .actions {
            margin-left: auto;
        }

        #calendar .today:after {
            top: -14px;
            right: -14px;
            width: 28px;
            height: 28px;
        }

        #calendar-title {
            font-size: 1.3em;
        }

        #calendar-quick-switch .material-icons {
            font-size: 2em;
        }
    }
</style>
{% endblock styles %}

{% block content %}
<div id="calendar" class="widget">
    <header id="calendar-header">
        <div id="calendar-quick-switch">
            <a
                id="calendar-quick-switch-prev"
                class="material-icons"
                href="{{ url_for('.calendar_month', month=previous) }}"
            >
                chevron_left
            </a>
            <a
                id="calendar-quick-switch-next"
                class="material-icons"
                href="{{ url_for('.calendar_month', month=next) }}"
            >
                chevron_right
            </a>
        </div>
        <h2 id="calendar-title">
            {{ date.format('MMMM YYYY', locale='fr') | capitalize }}
        </h2>
    </header>
    <main id="calendar-main">
        <div id="calendar-weekdays" class="calendar-row">
            <div class="calendar-weekday">Lun</div>
            <div class="calendar-weekday">Mar</div>
            <div class="calendar-weekday">Mer</div>
            <div class="calendar-weekday">Jeu</div>
            <div class="calendar-weekday">Ven</div>
            <div class="calendar-weekday">Sam</div>
            <div class="calendar-weekday">Dim</div>
        </div>
        <div id="calendar-days">
            {% for i in range(0, 6) %}
            <div class="calendar-row">
                {% for day in days[0 + i * 7:7 + i * 7] %}
                <a
                    class="
                        cell
                        {% if day.is_past %}past{% endif %}
                        {% if day.is_today %}today{% endif %}
                        {% if day.is_weekend %}weekend{% endif %}
                        {% if day.openings %}opening{% endif %}
                    "
                    href="{{ url_for('.calendar_day', month=day.date.format('YYYY-MM'), day=day.date.format('DD')) }}"
                >
                    <span class="cell-weekday">
                        {{ day.date.format('dddd') }}
                    </span>
                    <span class="cell-date">
                        {{ day }}
                    </span>
                    <span class="staffings">

                    </span>
                    <span class="actions">
                        <label>
                            <input type="checkbox">
                            <span>Dispo</span>
                        </label>
                    </span>
                </a>
                {% endfor %}
            </div>
            {% endfor %}
        </div>
    </main>
</div>
{% endblock content %}
