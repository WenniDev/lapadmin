{% extends "base.html.j2" %}

{% block styles %}
<style>
.actions a:hover {
    text-decoration: none;
}
.title {
    font-size: 1.5em;
    margin: 0.25em 0 1em;
}

.opening header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.visit .mark-finished,
.visit .mark-paused,
.visit.started .mark-started,
.visit. {
    display: none;
}
.visit.started .mark-paused,
.visit.started .mark-finished {
    display: initial;
}

.visit .paid-label {
    font-size: inherit;
    color: inherit;
    margin-left: 0.75em;
    cursor: pointer;
    white-space: nowrap;
}

.visit .paid-checkbox {
    position: static;
    opacity: 1;
    pointer-events: auto;
    appearance: auto;
    -webkit-appearance: checkbox;
    width: auto;
    height: auto;
    vertical-align: middle;
    margin-left: 0.4em;
}

.visit .unpaid-badge {
    display: none;
}
.visit.unpaid.finished .unpaid-badge {
    display: initial;
}

.visit .no-bill-badge {
    display: none;
}
.visit.paid.no-bills .no-bill-badge {
    display: initial;
}

.visit .incomplete-badge {
    display: none;
}
.visit.incomplete .incomplete-badge {
    display: initial;
}

.visit .billing-info {
    display: none;
    font-size: 0.85em;
    color: gray;
    margin-top: 0.25em;
    white-space: nowrap;
}
.visit.has-entry.finished .billing-info {
    display: block;
}
.visit .billed-amount {
    width: 3.5em !important;
    font-size: inherit;
    display: inline;
    text-align: right;
    margin-right: 0.25em;
    -moz-appearance: textfield;
}
.visit .billed-amount::-webkit-inner-spin-button,
.visit .billed-amount::-webkit-outer-spin-button {
    -webkit-appearance: none;
}
.visit .billed-amount.overridden {
    color: darkorange;
}

.visit .note {
    width: 100%;
    font-size: 0.85em;
    resize: vertical;
    min-height: 2em;
    border: 1px solid #ccc;
    padding: 0.2em 0.4em;
    box-sizing: border-box;
    margin: 0.5em 0;
}.visit.note-empty .note {
    display: none;
}
.visit .note-add {
    display: none;
    font-size: 0.8em;
    color: gray;
    cursor: pointer;
    margin-top: 0.4em;
}
.visit.note-empty .note-add {
    display: block;
}
.visit input {
    height: initial;
    width: 4em;
    border: 1px solid gray;
    font-size: 0.9em;
}

.visit .logs {
    font-size: 0.8em;
    color: gray;
    margin-left: 0.5em;
}

.visit .mark-now .material-icons {
    font-size: 1.3em;
}
</style>
{% endblock %}

{% block content %}
<div class="container">
    <h1>{{ date | arrow('format', 'D MMM YYYY') }}</h1>
</div>

{% for (opening, start_offset, end_offset) in openings %}
<div class="container widget opening" data-opening="{{ opening.id }}">
    <header>
        <div class="title">
            {{ opening.start | arrow('format', 'HH:mm') }}
            <sup>{{ start_offset }}</sup>
            <span>&#8212;</span>
            {{ opening.end | arrow('format', 'HH:mm') }}
            <sup>{{ end_offset }}</sup>
            <span class="badge">{{ opening.scope }}</span>
        </div>
        <div class="actions">
            <span class="delete-opening-wrapper {% if opening.visits %}tooltipped{% endif %}"
                  data-position="left"
                  data-tooltip="Impossible de supprimer une journée contenant des visites">
                <a class="btn waves-effect waves-light red opening-delete{% if opening.visits %} disabled{% endif %}"
                   href="{{ url_for('.opening_delete', id=opening.id) }}">
                    <i class="material-icons">delete</i>
                </a>
            </span>
        </div>
    </header>
    <main>
        <div class="row">
            <div class="input-field col s10">
                <label>Ajouter un visiteur</label>
                <input type="text" class="autocomplete visitors-input" name="add-visitor-text">
            </div>
            <div class="input-field col s2">
                <button class="btn waves-effect waves-light" type="submit" name="add-visitor-button">
                    <i class="material-icons">add</i>
                </button>
            </div>
        </div>
        <ul class="collection">
            {% for visit in opening.visits | sort(attribute='visitor') %}
            {% with visitor = visit.visitor %}
            <li
                class="
                    visit
                    collection-item
                    {% if visit.paid %}paid{% else %}unpaid{% endif %}
                    {% if visit.entry %}has-entry{% endif %}
                    {% if visit.finished %}finished{% endif %}
                    {% if not visit.note %}note-empty{% endif %}
                    {% if visit.visitor.is_incomplete %}incomplete{% endif %}
                    {% if not visit.bills %}no-bills{% endif %}
                    "
                data-visitor-id="{{ visitor.id }}"
            >
                <span class="right actions">
                    <span class="entry-actions">
                        <input
                            class="entry-time"
                            {% if visit.entry %}
                            value="{{ '%02d' % visit.entry.hour }}:{{ '%02d' % visit.entry.minute }}"
                            {% endif %}
                        >
                        <a class="mark-now">
                            <i class="material-icons">timer</i>
                        </a>
                    </span>
                    -
                    <span class="exit-actions">
                        <input
                            class="exit-time"
                            {% if visit.exit %}
                            value="{{ '%02d' % visit.exit.hour }}:{{ '%02d' % visit.exit.minute }}"
                            {% endif %}
                        >
                        <a class="mark-now">
                            <i class="material-icons">timer</i>
                        </a>
                    </span>
                    <a class="delete">
                        <i class="material-icons">delete</i>
                    </a>
                </span>
                {% include "_visitor_item.html.j2" %}
                <a href="{{ url_for('.visitor_edit', id=visitor.id) }}">
                    <i class="material-icons">edit</i>
                </a>
                <span class="badge red unpaid-badge">
                    Impayé
                </span>
                <span class="badge red no-bill-badge">
                    0 facture
                </span>
                <span class="badge orange incomplete-badge">
                    Incomplet
                </span>
                <span class="logs">
                </span>
                <div class="billing-info">
                    <span class="duration-display">
                        {% if visit.billed_duration is not none %}
                        {{ visit.duration | format_duration }} &rarr; {{ visit.billed_duration | format_duration }}
                        {% endif %}
                    </span>
                    =
                    <input
                        class="billed-amount{% if visit.billed_amount is not none %} overridden{% endif %}"
                        type="number"
                        step="0.5"
                        min="0"
                        value="{{ '%.2f' | format(visit.effective_price) if visit.effective_price is not none else '' }}"
                        data-computed="{{ '%.2f' | format(visit.computed_price) if visit.computed_price is not none else '' }}"
                    > &euro;
                    <label class="paid-label">
                        <input type="checkbox" class="paid-checkbox" {% if visit.paid %}checked{% endif %}>
                        Payé
                    </label>
                    <a href="{{ url_for('.visit_bills', opening_id=opening.id, visitor_id=visitor.id) }}" title="Lier factures" style="vertical-align:middle;margin-left:0.5em;">
                        <i class="material-icons" style="font-size:1.1em;">receipt</i> Factures ({{ visit.bills | length }})
                    </a>
                </div>
                <textarea class="note" placeholder="Note...">{{ visit.note or '' }}</textarea>
                <span class="note-add">+ Écrire une note...</span>
            </li>
            {% endwith %}
            {% endfor %}
        </ul>
    </main>
</div>
{% endfor %}

<div class="container widget">
    <div class="title">Créer une ouverture</div>
    {% include "_form_errors.html.j2" %}
    <form action="." method="post">
        {{ form.hidden_tag() }}
        <div class="row">
            <div class="input-field col s12 m6">
                <i class="material-icons prefix">date_range</i>
                <input
                    type="text"
                    name="{{ form.start_date.name }}"
                    id="{{ form.start_date.id }}"
                    class="datepicker"
                    value="{{ form.start_date.data }}"
                    disabled="disabled"
                >
                {{ form.start_date.label }}
            </div>
            <div class="input-field col s12 m6">
                <i class="material-icons prefix">access_time</i>
                <input
                    type="text"
                    name="{{ form.start_time.name }}"
                    id="{{ form.start_time.id }}"
                    class="timepicker"
                    value="{{ form.start_time.data or '16:00'}}"
                >
                {{ form.start_time.label }}
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12 m6">
                <i class="material-icons prefix">date_range</i>
                <input
                    type="text"
                    name="{{ form.end_date.name }}"
                    id="{{ form.end_date.id }}"
                    class="datepicker"
                    value="{{ form.end_date.data }}"
                >
                {{ form.end_date.label }}
            </div>
            <div class="input-field col s12 m6">
                <i class="material-icons prefix">access_time</i>
                <input
                    type="text"
                    name="{{ form.end_time.name }}"
                    id="{{ form.end_time.id }}"
                    class="timepicker"
                    value="{{ form.end_time.data or '22:00' }}"
                >
                {{ form.end_time.label }}
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12 m3">
                {{ form.scope }}
                {{ form.scope.label }}
            </div>
        </div>
        <button class="btn waves-effect waves-light" type="submit">Créer</button>
    </form>
</div>

{% endblock %}

{% block scripts %}
<script>
const BILLING_SEGMENT_MINUTES = {{ billing_segment_minutes }};
const BILLING_MINIMUM_MINUTES = {{ billing_minimum_minutes }};
const BILLING_MAX_MINUTES = {{ billing_max_minutes }};
const ENTRY_PRICE_PER_HOUR = {{ entry_price }};

function formatDuration(totalMinutes) {
    const hours = Math.floor(totalMinutes / 60);
    const mins = totalMinutes % 60;
    if (hours > 0) return mins > 0 ? `${hours}h${String(mins).padStart(2, '0')}` : `${hours}h`;
    return `${mins}min`;
}

function computeBilledMinutes(realMinutes) {
    const capped = Math.min(realMinutes, BILLING_MAX_MINUTES);
    const fullSegments = Math.floor(capped / BILLING_SEGMENT_MINUTES);
    const remainder = capped % BILLING_SEGMENT_MINUTES;
    let billedSegments;
    if (fullSegments === 0) {
        billedSegments = 1;
    } else if (remainder > BILLING_MINIMUM_MINUTES) {
        billedSegments = fullSegments + 1;
    } else {
        billedSegments = fullSegments;
    }
    return billedSegments * BILLING_SEGMENT_MINUTES;
}

function updateBillingInfo(visitContainer) {
    const entryInput = visitContainer.querySelector('.entry-time');
    const exitInput = visitContainer.querySelector('.exit-time');
    const billingInfo = visitContainer.querySelector('.billing-info');
    const durationDisplay = visitContainer.querySelector('.duration-display');
    const billedAmountInput = visitContainer.querySelector('.billed-amount');
    if (!entryInput.value || !exitInput.value) {
        if (durationDisplay) durationDisplay.textContent = '';
        return;
    }
    const [entryH, entryM] = entryInput.value.split(':').map(Number);
    const [exitH, exitM] = exitInput.value.split(':').map(Number);
    let realMinutes = (exitH * 60 + exitM) - (entryH * 60 + entryM);
    if (realMinutes < 0) realMinutes += 24 * 60;
    const billedMinutes = computeBilledMinutes(realMinutes);
    const computedPrice = (billedMinutes / 60 * ENTRY_PRICE_PER_HOUR).toFixed(2);
    if (durationDisplay) {
        durationDisplay.innerHTML = `${formatDuration(realMinutes)} &rarr; ${formatDuration(billedMinutes)}`;
    }
    if (billedAmountInput && !billedAmountInput.classList.contains('overridden')) {
        billedAmountInput.value = computedPrice;
        billedAmountInput.dataset.computed = computedPrice;
    } else if (billedAmountInput) {
        billedAmountInput.dataset.computed = computedPrice;
    }
}

document.addEventListener('DOMContentLoaded', () => {
    {% with name='visitors', data=visitors %}
    {% include "_autocomplete.js.j2" %}
    {% endwith %}

    const end_datepicker = M.Datepicker.getInstance(document.querySelector('[name="end_date"]'));
    end_datepicker.options.setDefaultDate = true;
    end_datepicker.options.defaultDate = new Date("{{ form.start_date.data }}");
    let minDate = new Date("{{ form.start_date.data }}");
    minDate.setDate(minDate.getDate() - 1);
    end_datepicker.options.minDate = minDate;
    end_datepicker.setDate(new Date("{{ form.start_date.data }}"));

    for (const openingContainer of document.querySelectorAll('[data-opening]')) {
        const addVisitorButton = openingContainer.querySelector('[name="add-visitor-button"]');
        const input = openingContainer.querySelector('[name="add-visitor-text"]');
        const openingId = openingContainer.dataset.opening;

        addVisitorButton.addEventListener('click', async () => {
            const visitor = input.value;
            const visitorId = visitor.match(/\(#(\d+)\)$/);
            if (!visitorId)
                return;

            const result = await fetch(`/api/openings/${openingId}/visitors/`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ visitor_id: visitorId[1] }),
            })
            if (!result.ok) {
                console.error('Failed to add visitor');
                return;
            }
            window.location.href = window.location.href;
        });

        for (const visitContainer of openingContainer.querySelectorAll('.visit')) {
            const visitorId = visitContainer.dataset.visitorId;
            const deleteButton = visitContainer.querySelector('.delete');
            const logsContainer = visitContainer.querySelector('.logs');

            async function setPaid(paid) {
                const result = await fetch(`/api/openings/${openingId}/visitors/${visitorId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ paid }),
                });
                if (!result.ok) {
                    console.error('Failed to update paid status');
                    return;
                }
                visitContainer.classList.toggle('paid', paid);
                visitContainer.classList.toggle('unpaid', !paid);
            }

            const paidCheckbox = visitContainer.querySelector('.paid-checkbox');
            if (paidCheckbox) paidCheckbox.addEventListener('change', () => setPaid(paidCheckbox.checked));

            const billedAmountInput = visitContainer.querySelector('.billed-amount');
            if (billedAmountInput) {
                async function saveBilledAmount() {
                    const val = billedAmountInput.value.trim();
                    const isOverride = val !== '' && val !== billedAmountInput.dataset.computed;
                    const result = await fetch(`/api/openings/${openingId}/visitors/${visitorId}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ billed_amount: isOverride ? parseFloat(val) : null }),
                    });
                    if (result.ok) {
                        billedAmountInput.classList.toggle('overridden', isOverride);
                        if (!isOverride) billedAmountInput.value = billedAmountInput.dataset.computed;
                        logsContainer.textContent = 'Enregistré';
                        setTimeout(() => { logsContainer.innerHTML = ''; }, 2000);
                    }
                }
                billedAmountInput.addEventListener('change', saveBilledAmount);
                billedAmountInput.addEventListener('blur', saveBilledAmount);
            }

            const noteInput = visitContainer.querySelector('.note');
            const noteAdd = visitContainer.querySelector('.note-add');

            noteAdd.addEventListener('click', () => {
                visitContainer.classList.remove('note-empty');
                noteInput.focus();
            });

            noteInput.addEventListener('blur', async () => {
                const result = await fetch(`/api/openings/${openingId}/visitors/${visitorId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ note: noteInput.value }),
                });
                if (result.ok) {
                    if (!noteInput.value.trim()) {
                        visitContainer.classList.add('note-empty');
                    }
                    logsContainer.textContent = 'Enregistr\u00e9';
                    setTimeout(() => { logsContainer.innerHTML = ''; }, 2000);
                }
            });

            deleteButton.addEventListener('click', async () => {
                const result = await fetch(`/api/openings/${openingId}/visitors/${visitorId}`, {
                    method: 'DELETE',
                });
                if (!result.ok) {
                    console.error('Failed to delete visitor');
                    return;
                }
                visitContainer.remove();

                // Update delete opening button status if needed
                if (openingContainer.querySelector('.visit')) {
                    return;
                }
                const wrapper = openingContainer.querySelector('.delete-opening-wrapper');
                openingContainer.querySelector('.opening-delete').classList.remove('disabled');
                M.Tooltip.getInstance(wrapper)?.destroy();
                wrapper.classList.remove('tooltipped');
            });

            for (const field of ['entry', 'exit']) {
                const timeInput = visitContainer.querySelector(`.${field}-time`);
                const markNow = visitContainer.querySelector(`.${field}-actions .mark-now`);

                async function update() {
                    console.log(`Updating ${field} time for visitor ${visitorId}`);
                    const result = await fetch(`/api/openings/${openingId}/visitors/${visitorId}`, {
                        method: 'PATCH',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ [field]: timeInput.value }),
                    });
                    if (!result.ok) {
                        console.error('Failed to update visitor');
                        logsContainer.innerHTML = '<span style="color: red;">Erreur</span>';
                    } else {
                        logsContainer.textContent = 'Enregistré';
                        if (field === 'exit') {
                            visitContainer.classList.toggle('finished', !!timeInput.value);
                        } else if (field === 'entry') {
                            visitContainer.classList.toggle('has-entry', !!timeInput.value);
                        }
                        updateBillingInfo(visitContainer);
                    }
                    setTimeout(() => {
                        logsContainer.innerHTML = '';
                    }, 2000);
                }

                markNow.addEventListener('click', async () => {
                    const now = new Date();
                    const hours = now.getHours().toString().padStart(2, '0');
                    const minutes = now.getMinutes().toString().padStart(2, '0');
                    timeInput.value = `${hours}:${minutes}`;

                    update();
                });

                timeInput.addEventListener('change', update);
                timeInput.addEventListener('blur', update);
            }
        }
    }
});
</script>
{% endblock scripts %}
